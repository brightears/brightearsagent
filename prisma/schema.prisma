// Bright Ears — AI back office for wedding/event performer businesses.
// MVP schema: email-spine lead pipeline, draft-approve loop, follow-up sequences,
// in-app gig calendar. Polymorphic PerformerKind from day one.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerformerKind {
  DJ
  BAND
  SINGER
  MAGICIAN
  DANCER
  MC
  PHOTO_BOOTH
  MUSICIAN
  COMEDIAN
  OTHER
}

enum PlanTier {
  TRIAL   // free / not subscribed — agent paused until a paid plan (no auto trial; fails closed)
  STARTER // $25/mo — complete agent: 15 inquiries/mo, approve every send
  PRO     // $79/mo — 60 inquiries/mo + per-source auto-send + 3 cities
  STUDIO  // $149/mo — 150 inquiries/mo, auto-send, all cities (roster lands with P13)
}

enum LeadSource {
  WEBSITE_FORM
  PLAIN_EMAIL
  THE_KNOT
  WEDDINGWIRE
  BARK
  GIGSALAD
  THUMBTACK
  VENUE_OUTREACH // a venue replying to a Hunt pitch (P8.3 reply capture)
  OTHER
}

enum LeadStatus {
  NEW          // parsed, awaiting triage/draft
  SPAM         // triaged out — never shown unless owner opts in
  DRAFTED      // reply drafted, awaiting owner approval
  REPLIED      // first reply sent
  IN_SEQUENCE  // follow-ups running
  ENGAGED      // prospect replied — back to human/draft loop
  BOOKED       // won — hard-stops all automation
  DEAD         // lost/unresponsive after sequence — hard-stops all automation
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum DraftStatus {
  PENDING
  SENDING // 10.10: claimed for send (atomic PENDING->SENDING) - closes the double-send window
  APPROVED
  EDITED    // approved with owner edits (edits feed voice tuning)
  REJECTED
  EXPIRED
}

// One tenant = one performer business (1-5 people).
model Business {
  id                   String        @id @default(cuid())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  name                 String
  slug                 String        @unique // leads@{slug}.in.brightears.io
  ownerEmail           String        @unique
  ownerName            String
  performerKind        PerformerKind @default(DJ)
  country              String        @default("US") // drives compliance footer (CAN-SPAM/PECR/CASL/Spam Act)
  timezone             String        @default("America/New_York")
  currency             String        @default("USD")
  websiteUrl           String?
  bookingLinkUrl       String? // owner's EXISTING booking/contract/deposit page — the AI carries it to the close
  replyToEmail         String? // Reply-To on outbound; defaults to ownerEmail
  voiceSamples         String? // pasted past replies — seeds draft voice
  // Structured voice signals (June 2026) — complement the samples; drafter emits
  // a rule only for fields that are set. voiceUsesEmoji: null=unspecified.
  voiceGreeting        String? // how they open ("Hey [name]!", "Hi [name],")
  voiceSignoff         String? // how they sign off ("Cheers, Sam", "Talk soon —")
  voiceUsesEmoji       Boolean? // null = unspecified, true = occasional, false = never
  voicePhrases         String? // words/expressions they lean on
  autoSendSources      LeadSource[]  @default([]) // sources the owner trusts for auto-send
  // 10.3: sources the owner said "keep reviewing" to when the graduation
  // prompt offered auto-send - remembered so the ask never nags twice.
  autoSendDeclinedSources LeadSource[] @default([])
  // Gmail forwarding-confirmation capture (P2, July 2026): the provider's
  // verification email is intercepted BEFORE parse/triage (the LLM fallback
  // reads it as an automated notice and ignores it — the artist could never
  // approve forwarding self-serve) and surfaced in onboarding step 5.
  forwardingConfirmUrl  String?
  forwardingConfirmCode String?
  forwardingConfirmAt   DateTime?
  // Smart-attachment autonomy: auto-attach the press kit / a quote when the
  // drafter detects the client wants one. Default off (a binding quote is opt-in).
  autoAttachProfile    Boolean       @default(false)
  autoAttachQuote      Boolean       @default(false)
  plan                 PlanTier      @default(TRIAL)
  trialEndsAt          DateTime?
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique // audit NF18: one subscription ↔ one business; lets webhook use findUnique
  // Phase 10.2b: discovery-scan budget guard — a live scan costs real Serper
  // queries; refuse a new scan if one ran < 20h ago (manual --force bypasses).
  lastDiscoveryScanAt  DateTime?
  // 10.2c: warm-battery wheel — total scans run; the WARM query battery fires
  // on every 3rd scan (count % 3 === 0). A COUNTER, not date-modulo on
  // lastDiscoveryScanAt: scans run irregularly (manual --force, missed crons),
  // so a date-modulo could starve the warm wheel for weeks; a counter
  // guarantees exactly 1-in-3 regardless of cadence.
  discoveryScanCount   Int       @default(0)
  // Travel Mode: Home Base = serviceCities (where the artist is normally
  // available). homeRadiusKm is advisory for now (UI shows it; scan scoping
  // doesn't act on it yet) — packaging: founder decision (included for all).
  homeRadiusKm         Int?

  // --- Artist profile (Phase 10.1) — what the sales agent pitches WITH.
  // Lives on Business (not a 1:1 side table): every field is tenant-singular,
  // read together with the rest of the tenant row on every pitch/EPK render.
  // Matching fields (who/where the agent may pitch):
  genres         String[] @default([]) // genre/vibe tags, free-form (~5-10)
  eventTypes     String[] @default([]) // weddings, corporate, club nights...
  serviceCities  String[] @default([]) // named cities/areas served
  travelPolicy   String? // "within 100km included, beyond at cost" etc.
  feeFloor       Int? // cents — the agent NEVER pitches below this (one-off floor)
  feeSweetSpot   Int? // cents — the fee the agent aims for
  pitchLanguages String[] @default(["en"])
  insured        Boolean  @default(false)
  // Onboarding dials (June 2026): how the artist works — non-narrowing signals
  // that replaced the event-typed package builder. All fees in Business.currency.
  gigTypes       String[] @default([]) // "one-off" and/or "residency" (both = both present)
  acceptsTravel  Boolean  @default(false) // open to gigs beyond service cities
  residencyRate  Int? // cents — per-night going rate for a regular slot (≠ one-off feeFloor)
  // Pitching fields (the ammunition):
  headline     String? // <=80 chars, the one-liner venues read first
  bio          String? // 40-120 words, artist voice
  videoLinks   String[] @default([]) // YouTube/Vimeo URLs (embeddable — EPK player + strength proof bar)
  photoUrls    String[] @default([]) // external URLs for v1 — no upload infra yet
  socialLinks  String[] @default([]) // IG/TikTok/X/SoundCloud/Mixcloud/Spotify/site — platform inferred from host
  riderNotes   String? // "how you perform & what you need" — setup/space/power/sound; feeds drafter + pitch
  reviewQuotes String[] @default([]) // 1-3 short client quotes
  notableVenues String[] @default([])
  epkEnabled   Boolean  @default(true) // hosted press kit at /epk/{slug}

  members    Member[]
  performers Performer[]
  packages   Package[]
  gigs       Gig[]
  leads      Lead[]
  sequences  SequenceTemplate[]
  llmUsage   LlmUsage[]
  pushSubscriptions PushSubscription[]
  venues               Venue[]
  venuePitches         VenuePitch[]
  outreachSuppressions OutreachSuppression[]
  mailboxConnection    MailboxConnection?
  travelWindows        TravelWindow[]
}

// One row per (business, device) the owner approved push on. Scoped by business
// so the same physical device can serve an owner who runs two businesses, and
// one tenant can never reassign or clobber another tenant's registration.
model PushSubscription {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  endpoint   String
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@unique([businessId, endpoint])
}

model Member {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String
  isOwner     Boolean  @default(false)
  clerkUserId String?  @unique // linked on first sign-in; null = invited/not yet signed in
  createdAt   DateTime @default(now())

  @@unique([businessId, email])
}

// Multi-op: each bookable person/unit. Solo ops have exactly one.
model Performer {
  id         String        @id @default(cuid())
  businessId String
  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  kind       PerformerKind @default(DJ)
  active     Boolean       @default(true)

  gigs Gig[]
}

// Rate card: what the AI is allowed to quote.
model Package {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String // "6-hour wedding package"
  description String
  priceMin    Int // cents
  priceMax    Int? // cents; null = fixed price
  eventTypes  String[] // ["wedding", "corporate", "birthday"]
  active      Boolean  @default(true)
}

// In-app gig calendar — the availability source (no OAuth at MVP).
model Gig {
  id          String     @id @default(cuid())
  businessId  String
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  performerId String?
  performer   Performer? @relation(fields: [performerId], references: [id], onDelete: SetNull)
  date        DateTime // event date (tenant tz)
  startTime   String? // "18:00"
  endTime     String?
  title       String
  venue       String?
  // 11.1 money-loop-lite: what the gig is worth, minor units in the artist's
  // own currency (Business.currency). Captured optionally at "Mark booked" -
  // powers booked-value receipts (Results, weekly report, ROI email).
  value       Int?
  leadId      String?    @unique
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([businessId, date])
}

model Lead {
  id           String     @id @default(cuid())
  businessId   String
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  source       LeadSource
  status       LeadStatus @default(NEW)
  // Reply capture (P8.3): when a venue replies to a Hunt pitch, the
  // conversation enters THIS pipeline as a Lead (ADR-004: replies merge into
  // the existing close flow) — venueId links it back to the Hunt card.
  venueId      String?
  sourceVenue  Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  // Parsed couple/client details (all nullable — parser fills what it finds)
  clientName   String?
  clientEmail  String?
  clientPhone  String?
  eventType    String? // "wedding", "corporate", ...
  eventDate    DateTime?
  venue        String?
  guestCount   Int?
  budgetHint   String?
  rawSubject   String?
  rawBody      String // original inbound payload (text)
  spamScore    Float? // triage classifier output
  spamReason   String?
  firstReplyAt DateTime? // for the "median response time" report
  bookedAt     DateTime?
  deadAt       DateTime?
  optedOut     Boolean    @default(false) // hard-stop flag for sequences

  messages    Message[]
  drafts      Draft[]
  gig         Gig?
  sequenceRun SequenceRun?

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

// Full conversation thread per lead (inbound + outbound).
model Message {
  id                String           @id @default(cuid())
  leadId            String
  lead              Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
  direction         MessageDirection
  subject           String?
  body              String
  fromEmail         String?
  toEmail           String?
  providerMessageId String?          @unique // dedup backstop for webhook redelivery (nulls allowed multiple)
  draftId           String?          @unique
  draft             Draft?           @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

// The approve-from-phone loop.
model Draft {
  id           String      @id @default(cuid())
  leadId       String
  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  status       DraftStatus @default(PENDING)
  subject      String
  body         String
  editedBody   String? // owner's edited version (feeds voice tuning)
  decidedAt    DateTime?
  expiresAt    DateTime? // stale drafts expire (event passed, lead dead)
  // 10.4 "sending soon" buffer: autonomous sends (auto-send replies, autopilot
  // follow-ups) schedule here instead of firing instantly - the owner gets a
  // window to Hold; the sequence tick fires whatever elapsed. Null = manual.
  scheduledSendAt DateTime?
  isFollowUp   Boolean     @default(false)
  // 11.2: a booking-confirmation draft - the ONE draft allowed to send on a
  // BOOKED lead (deterministic template, carries bookingLinkUrl + quote PDF).
  isConfirmation Boolean   @default(false)
  sequenceStep Int?
  // Drafter intent flags (June 2026) — did the inquiry ask for a profile / a
  // price? Drives the attach prompts + auto-attach autonomy.
  wantsProfile Boolean     @default(false)
  wantsQuote   Boolean     @default(false)
  // Draft-aging re-ping (P4.3, July 2026): stamped when the one-and-only
  // "still waiting" nudge went out, ~4h after the draft was created. One push
  // per draft was fragile for people who work nights; more than two is spam.
  agingPingAt  DateTime?
  message      Message?

  @@index([leadId, status])
  @@index([status, expiresAt]) // cron draft-expiry sweep
}

// Owner-configurable follow-up cadence (default: day 2, 5, 9).
model SequenceTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String   @default("Default follow-up")
  stepsDays  Int[]    @default([2, 5, 9]) // days after last outbound with no reply
  active     Boolean  @default(true)

  runs SequenceRun[]
}

model SequenceRun {
  id          String           @id @default(cuid())
  leadId      String           @unique
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  templateId  String
  template    SequenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  nextRunAt   DateTime?
  stoppedAt   DateTime? // set on BOOKED/DEAD/ENGAGED/opt-out — never resumes
  stopReason  String?

  @@index([stoppedAt, nextRunAt]) // cron due-runs query
}

// Token/cost ledger per tenant (margin visibility from day one).
model LlmUsage {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  purpose      String // "parse" | "triage" | "draft" | "followup"
  model        String
  inputTokens  Int
  outputTokens Int

  @@index([businessId, createdAt])
}

// ---------------------------------------------------------------------------
// Venue discovery (Phase 10.2, ADR-004) — the sales agent's prospect list.
// ---------------------------------------------------------------------------

enum VenueKind {
  BAR
  ROOFTOP
  HOTEL
  RESTAURANT
  EVENT_SPACE
  CLUB
  OTHER
}

enum VenueStatus {
  DISCOVERED      // found by a scanner or seed — not yet judged
  QUALIFIED       // scored + fit — eligible for pitching (10.3)
  PITCH_DRAFTED   // pitch awaiting owner approval
  PITCHED         // pitch sent to the venue's published contact
  REPLIED         // venue answered — conversation begins
  IN_CONVERSATION // active back-and-forth
  BOOKED          // won — hard-stops all automation
  DEAD            // lost/unresponsive — hard-stops all automation
  SUPPRESSED      // never contact again (opt-out, C&D, owner kill) — never resurrected
}

enum SignalType {
  NEW_OPENING         // venue just opened (press/roundup/new listing)
  OPENING_SOON        // announced/under construction/staffing up to open
  HIRING              // hiring events/bar staff — activity proxy
  NEW_SOCIAL          // brand-new venue social account
  PRESS               // other press coverage
  MANUAL              // owner added it by hand
  HOSTS_ENTERTAINMENT // 10.2c: existing venue demonstrably books DJs/live acts
  EVENT_PROGRAM       // 10.2c: live events page / "what's on" calendar found
  TEAM_CONTACT        // 10.2c: a named events manager/coordinator in a public snippet
}

// Phase 10.2c: opportunity temperature — TIMING, kept separate from fit.
// Declaration order matters: Postgres sorts enum values by definition order,
// so `orderBy: { temperature: "asc" }` yields HOT → WARM → SEED in the feed.
enum VenueTemperature {
  HOT  // opening/just-opened — deciding entertainment NOW
  WARM // existing venue that already buys entertainment, not posting a need
  SEED // relationship-planting — books eventually; one polite intro, no follow-ups
}

// One prospect venue, TENANT-SCOPED: every artist gets their own venue rows
// for v1 — simpler isolation (status/score/suppression are inherently
// per-artist anyway). FUTURE REFACTOR: a global venue graph (one canonical
// Venue + per-tenant VenueProspect join) once multiple tenants hunt the same
// metros and discovery cost is worth sharing.
model Venue {
  id                 String      @id @default(cuid())
  businessId         String
  business           Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leads              Lead[] // reply-capture conversations (P8.3)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  name               String
  city               String
  country            String // ISO-2, recipient-side — drives the 10.3 jurisdiction rules
  kind               VenueKind   @default(OTHER)
  website            String?
  instagram          String?
  bookingEmail       String?
  bookingContactName String?
  contactSource      String? // where the email was found (venue site/press/...) — provenance for trust
  status             VenueStatus @default(DISCOVERED)
  // 10.2c: FIT (fitScore) and TIMING (temperature/timingScore) stay separate —
  // a perfect-fit hotel bar can still be months from a booking decision.
  temperature        VenueTemperature @default(HOT) // existing rows = the hot scanner's finds
  timingScore        Int? // 0-100 short-term-booking likelihood (lib/venues/timing.ts)
  // The facts proving this venue buys entertainment ("runs Friday DJ sets per
  // its events page") — each traceable to a search snippet; feeds pitch
  // grounding (rule 2b) and the honest line on WARM/SEED cards.
  entertainmentEvidence String[] @default([])
  // When the ONLY source naming an events contact is linkedin.com we store the
  // URL for the handoff card and NEVER a name from it (ADR-004: LinkedIn is
  // find-only; profile data stays on LinkedIn).
  linkedinUrl        String?
  fitScore           Int? // 0-100 from lib/venues/score.ts
  fitReasons         String[]    @default([]) // <=3 plain-language reasons (feed card)
  caution            String? // <=1 plain-language caution
  lastSignalAt       DateTime?
  pitchedAt          DateTime?
  // Reply capture (P8.3): stamped when the venue's FIRST reply lands in the
  // pipeline — replies/sent is the 10.9 beta-gate number.
  repliedAt          DateTime?
  // 12.4 residency play kit: the owner's private field notes on this venue -
  // names met, visits, vibe. Never leaves the dashboard, never enters a pitch.
  staffNotes         String?
  // 12.4: stamped when the 180-day re-touch arc returns a silent PITCHED
  // venue to the feed as "warm again" (fair to knock twice).
  retouchedAt        DateTime?
  suppressedReason   String?
  // Travel Mode: the TravelWindow this venue was discovered for (null = a
  // home-base hunt). Lets the feed label travel finds ("Travel · Lisbon") and
  // the pitch be date-bounded to the window's city + dates. SetNull so deleting
  // a window doesn't take its discovered venues with it.
  travelWindowId     String?
  travelWindow       TravelWindow? @relation(fields: [travelWindowId], references: [id], onDelete: SetNull)

  signals VenueSignal[]
  pitches VenuePitch[]

  @@unique([businessId, name, city]) // dedup key for ingest upserts
  @@index([businessId, status])
  @@index([businessId, fitScore])
}

// One observed piece of evidence about a venue (append-only provenance trail).
model VenueSignal {
  id         String     @id @default(cuid())
  venueId    String
  venue      Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  type       SignalType
  summary    String // one plain-language line, e.g. "Rooftop bar opened May 28 per Manchester Evening News"
  sourceUrl  String // dedup key per venue — same URL never appended twice
  observedAt DateTime // when the signal was true (publish date), not when we saw it
  createdAt  DateTime   @default(now())

  @@index([venueId])
}

enum VenuePitchStatus {
  PENDING   // drafted, awaiting owner review
  APPROVED  // owner approved — parked until a mailbox is connected (10.5)
  SENDING   // 10.5: claimed for send (atomic APPROVED→SENDING) — in flight, no second send
  DISCARDED // owner killed it; venue returns to DISCOVERED
  SENT      // 10.5: delivered via the artist's own mailbox
  EXPIRED   // went stale before a decision
}

// One generated venue pitch (Phase 10.3, ADR-004). NOT unique per venue —
// a discarded pitch may be followed by a fresh draft later; history stays.
// The dedupe rule (max one PENDING per venue) is enforced in the action, not
// the schema.
model VenuePitch {
  id         String           @id @default(cuid())
  venueId    String
  venue      Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  businessId String
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  subject    String
  body       String // clean editable copy — the jurisdiction footer is NEVER stored here
  language   String           @default("en")
  status     VenuePitchStatus @default(PENDING)
  // HOT follow-up (P8.4): the one polite bump ~6 days after a HOT pitch went
  // out unanswered. Self-relation: a child pitch points at the pitch it bumps;
  // "no follow-up yet" = no child exists. WARM/SEED never get one (10.2c law).
  followUpOfId String?
  followUpOf   VenuePitch?  @relation("PitchFollowUp", fields: [followUpOfId], references: [id], onDelete: SetNull)
  followUps    VenuePitch[] @relation("PitchFollowUp")
  // 10.2c: temperature SNAPSHOT at draft time — drives the daily caps count
  // (lib/outreach/caps.ts) and the sequencing guard: WARM/SEED pitches must
  // NEVER enter any follow-up sequence (one polite intro is the whole play).
  temperature VenueTemperature @default(HOT)
  // Snapshot of lib/outreach/jurisdiction.ts mode at draft time ("STANDARD" |
  // "CONSENT" | "STRICT") — drives the review card's handoff/auto-send rules.
  jurisdictionMode String
  // LLM provenance (optional — LlmUsage holds the token ledger).
  model        String?
  inputTokens  Int?
  outputTokens Int?
  // Owner edits (voice-tuning signal, same pattern as Draft.editedBody).
  editedSubject String?
  editedBody    String?
  decidedAt     DateTime?
  // 10.5: own-mailbox send (Gmail OAuth). sentAt is the delivery moment;
  // providerMessageId is the Gmail message id — kept for future reply
  // threading AND as the idempotency anchor (a SENT pitch never re-sends).
  sentAt            DateTime?
  providerMessageId String?

  @@index([venueId])
  @@index([businessId, status])
}

// Master per-tenant do-not-contact list (ADR-004 hard cap). Checked at ingest
// (never create a venue around a suppressed email) and again before any send.
model OutreachSuppression {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email      String // ALWAYS lowercased before write/compare
  reason     String // "unsubscribe" | "cease-and-desist" | "owner" | ...
  createdAt  DateTime @default(now())

  @@unique([businessId, email])
}

// ---------------------------------------------------------------------------
// Travel Mode — the artist's HOME BASE is Business.serviceCities (where
// they're normally available). When they travel, they add a TRAVEL WINDOW ("in
// Lisbon Aug 4-11") and the Hunt ALSO scans that city for guest-spot/residency/
// private-event work for those dates, drafting DATE-BOUNDED outreach. The
// window's country drives jurisdiction at the destination (not the home
// country). packaging: founder decision — included for ALL tiers for now (no
// per-tier limits on travel windows).
// ---------------------------------------------------------------------------

enum TravelWindowStatus {
  ACTIVE    // live or upcoming — the Hunt scans it (lead-time gated)
  CANCELLED // owner removed it before it ran out — never scanned
  EXPIRED   // endDate passed — auto-expired at scan start, excluded
}

model TravelWindow {
  id         String             @id @default(cuid())
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  city       String
  country    String // ISO-2 — drives the DESTINATION jurisdiction (ADR-004 D4)
  // Date-only semantics (stored as DateTime; time component ignored — the
  // window is inclusive of both dates in the tenant's day sense).
  startDate  DateTime
  endDate    DateTime
  radiusKm   Int? // advisory, like homeRadiusKm
  feeOverride Int? // cents — optional travel-city fee floor; null = use profile
  roleTags   String[]           @default([]) // "guest-spot" | "residency" | "private-event"
  status     TravelWindowStatus @default(ACTIVE)

  venues Venue[]

  @@index([businessId, status])
}

// ---------------------------------------------------------------------------
// Own-mailbox sending (Phase 10.5, ADR-004 Decision 4) — proactive venue
// pitches send from the ARTIST'S own Gmail/Microsoft inbox via OAuth, never
// from shared Postmark infrastructure (one artist's cold mail must never
// endanger the reactive product's deliverability). gmail.send scope ONLY —
// reply capture (readonly/modify) is a later phase.
// ---------------------------------------------------------------------------

enum MailboxProvider {
  GOOGLE
  MICROSOFT // schema-ready; Phase 10.5 ships GOOGLE only
}

enum MailboxStatus {
  CONNECTED // tokens valid, sends allowed
  REVOKED   // owner disconnected (or provider revoked) — reconnect to send
  ERROR     // a send hit a dead/expired token — reconnect to clear
}

// One connected sending mailbox per tenant. Tokens are stored ENCRYPTED ONLY
// (AES-256-GCM via lib/crypto/tokens.ts) — the plaintext never touches the DB
// or a log. 1:1 with Business (businessId @unique): one sending identity.
model MailboxConnection {
  id              String          @id @default(cuid())
  businessId      String          @unique
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  provider        MailboxProvider @default(GOOGLE)
  email           String // the connected address (From + Reply-To on sends)
  accessTokenEnc  String // AES-256-GCM ciphertext — never plaintext
  refreshTokenEnc String // AES-256-GCM ciphertext — never plaintext
  expiresAt       DateTime // access-token expiry; refreshed when within 60s
  scope           String // granted scopes (audit: must include gmail.send)
  status          MailboxStatus   @default(CONNECTED)
  lastError       String? // friendly reason when status = ERROR
  connectedAt     DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// Marketing email captures (free tools, templates download, waitlist-ish).
model MarketingContact {
  id        String   @id @default(cuid())
  email     String
  source    String // "reply-generator" | "templates" | "roi-calculator"
  createdAt DateTime @default(now())

  @@unique([email, source])
}

// Idempotency ledger for Stripe webhooks (audit B1). Stripe retries a delivery
// for up to ~3 days until it gets a 2xx; the webhook checks this table on
// `event.id` BEFORE applying side effects and records it after, so a retried
// delivery can never double-apply a plan/subscription change.
model ProcessedStripeEvent {
  id          String   @id // Stripe event.id (evt_...)
  type        String // event.type, for debugging/audit
  processedAt DateTime @default(now())
}

// Ops heartbeat stamps (P7.4): each cron upserts its key at tick start so
// /api/health can flag a silently-dead cron — the sequences tick IS the
// product ("follow-up until booked-or-dead"), and before this a stopped cron
// looked green everywhere (the Render wrapper even exited 0 on HTTP failure).
model OpsStamp {
  key String   @id // "cron:sequences" | "cron:discovery" | "cron:weekly-report" | "cron:margin-guardrail"
  at  DateTime
}
