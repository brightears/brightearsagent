// Bright Ears — AI back office for wedding/event performer businesses.
// MVP schema: email-spine lead pipeline, draft-approve loop, follow-up sequences,
// in-app gig calendar. Polymorphic PerformerKind from day one.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerformerKind {
  DJ
  BAND
  SINGER
  MAGICIAN
  DANCER
  MC
  PHOTO_BOOTH
  MUSICIAN
  COMEDIAN
  OTHER
}

enum PlanTier {
  TRIAL   // 14 days, full capability, no card
  STARTER // $25/mo — complete assistant: 15 leads/mo, 1 performer, approve every send
  PRO     // $79/mo — 60 leads/mo + per-source auto-send autopilot
  STUDIO  // $149/mo — 150 leads/mo, multi-performer routing, team seats
}

enum LeadSource {
  WEBSITE_FORM
  PLAIN_EMAIL
  THE_KNOT
  WEDDINGWIRE
  BARK
  GIGSALAD
  THUMBTACK
  OTHER
}

enum LeadStatus {
  NEW          // parsed, awaiting triage/draft
  SPAM         // triaged out — never shown unless owner opts in
  DRAFTED      // reply drafted, awaiting owner approval
  REPLIED      // first reply sent
  IN_SEQUENCE  // follow-ups running
  ENGAGED      // prospect replied — back to human/draft loop
  BOOKED       // won — hard-stops all automation
  DEAD         // lost/unresponsive after sequence — hard-stops all automation
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum DraftStatus {
  PENDING
  APPROVED
  EDITED    // approved with owner edits (edits feed voice tuning)
  REJECTED
  EXPIRED
}

// One tenant = one performer business (1-5 people).
model Business {
  id                   String        @id @default(cuid())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  name                 String
  slug                 String        @unique // leads@{slug}.in.brightears.io
  ownerEmail           String        @unique
  ownerName            String
  performerKind        PerformerKind @default(DJ)
  country              String        @default("US") // drives compliance footer (CAN-SPAM/PECR/CASL/Spam Act)
  timezone             String        @default("America/New_York")
  currency             String        @default("USD")
  websiteUrl           String?
  bookingLinkUrl       String? // owner's EXISTING booking/contract/deposit page — the AI carries it to the close
  replyToEmail         String? // Reply-To on outbound; defaults to ownerEmail
  voiceSamples         String? // pasted past replies — seeds draft voice
  autoSendSources      LeadSource[]  @default([]) // sources the owner trusts for auto-send
  plan                 PlanTier      @default(TRIAL)
  trialEndsAt          DateTime?
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?

  // --- Artist profile (Phase 10.1) — what the sales agent pitches WITH.
  // Lives on Business (not a 1:1 side table): every field is tenant-singular,
  // read together with the rest of the tenant row on every pitch/EPK render.
  // Matching fields (who/where the agent may pitch):
  genres         String[] @default([]) // genre/vibe tags, free-form (~5-10)
  eventTypes     String[] @default([]) // weddings, corporate, club nights...
  serviceCities  String[] @default([]) // named cities/areas served
  travelPolicy   String? // "within 100km included, beyond at cost" etc.
  feeFloor       Int? // cents — the agent NEVER pitches below this
  feeSweetSpot   Int? // cents — the fee the agent aims for
  pitchLanguages String[] @default(["en"])
  insured        Boolean  @default(false)
  // Pitching fields (the ammunition):
  headline     String? // <=80 chars, the one-liner venues read first
  bio          String? // 40-120 words, artist voice
  videoLinks   String[] @default([]) // YouTube/Vimeo URLs
  photoUrls    String[] @default([]) // external URLs for v1 — no upload infra yet
  reviewQuotes String[] @default([]) // 1-3 short client quotes
  notableVenues String[] @default([])
  epkEnabled   Boolean  @default(true) // hosted press kit at /epk/{slug}

  members    Member[]
  performers Performer[]
  packages   Package[]
  gigs       Gig[]
  leads      Lead[]
  sequences  SequenceTemplate[]
  llmUsage   LlmUsage[]
  pushSubscriptions PushSubscription[]
  venues               Venue[]
  venuePitches         VenuePitch[]
  outreachSuppressions OutreachSuppression[]
}

// One row per (business, device) the owner approved push on. Scoped by business
// so the same physical device can serve an owner who runs two businesses, and
// one tenant can never reassign or clobber another tenant's registration.
model PushSubscription {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  endpoint   String
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@unique([businessId, endpoint])
}

model Member {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String
  isOwner     Boolean  @default(false)
  clerkUserId String?  @unique // linked on first sign-in; null = invited/not yet signed in
  createdAt   DateTime @default(now())

  @@unique([businessId, email])
}

// Multi-op: each bookable person/unit. Solo ops have exactly one.
model Performer {
  id         String        @id @default(cuid())
  businessId String
  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  kind       PerformerKind @default(DJ)
  active     Boolean       @default(true)

  gigs Gig[]
}

// Rate card: what the AI is allowed to quote.
model Package {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String // "6-hour wedding package"
  description String
  priceMin    Int // cents
  priceMax    Int? // cents; null = fixed price
  eventTypes  String[] // ["wedding", "corporate", "birthday"]
  active      Boolean  @default(true)
}

// In-app gig calendar — the availability source (no OAuth at MVP).
model Gig {
  id          String     @id @default(cuid())
  businessId  String
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  performerId String?
  performer   Performer? @relation(fields: [performerId], references: [id], onDelete: SetNull)
  date        DateTime // event date (tenant tz)
  startTime   String? // "18:00"
  endTime     String?
  title       String
  venue       String?
  leadId      String?    @unique
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([businessId, date])
}

model Lead {
  id           String     @id @default(cuid())
  businessId   String
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  source       LeadSource
  status       LeadStatus @default(NEW)
  // Parsed couple/client details (all nullable — parser fills what it finds)
  clientName   String?
  clientEmail  String?
  clientPhone  String?
  eventType    String? // "wedding", "corporate", ...
  eventDate    DateTime?
  venue        String?
  guestCount   Int?
  budgetHint   String?
  rawSubject   String?
  rawBody      String // original inbound payload (text)
  spamScore    Float? // triage classifier output
  spamReason   String?
  firstReplyAt DateTime? // for the "median response time" report
  bookedAt     DateTime?
  deadAt       DateTime?
  optedOut     Boolean    @default(false) // hard-stop flag for sequences

  messages    Message[]
  drafts      Draft[]
  gig         Gig?
  sequenceRun SequenceRun?

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

// Full conversation thread per lead (inbound + outbound).
model Message {
  id                String           @id @default(cuid())
  leadId            String
  lead              Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
  direction         MessageDirection
  subject           String?
  body              String
  fromEmail         String?
  toEmail           String?
  providerMessageId String?          @unique // dedup backstop for webhook redelivery (nulls allowed multiple)
  draftId           String?          @unique
  draft             Draft?           @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

// The approve-from-phone loop.
model Draft {
  id           String      @id @default(cuid())
  leadId       String
  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  status       DraftStatus @default(PENDING)
  subject      String
  body         String
  editedBody   String? // owner's edited version (feeds voice tuning)
  decidedAt    DateTime?
  expiresAt    DateTime? // stale drafts expire (event passed, lead dead)
  isFollowUp   Boolean     @default(false)
  sequenceStep Int?
  message      Message?

  @@index([leadId, status])
  @@index([status, expiresAt]) // cron draft-expiry sweep
}

// Owner-configurable follow-up cadence (default: day 2, 5, 9).
model SequenceTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String   @default("Default follow-up")
  stepsDays  Int[]    @default([2, 5, 9]) // days after last outbound with no reply
  active     Boolean  @default(true)

  runs SequenceRun[]
}

model SequenceRun {
  id          String           @id @default(cuid())
  leadId      String           @unique
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  templateId  String
  template    SequenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  nextRunAt   DateTime?
  stoppedAt   DateTime? // set on BOOKED/DEAD/ENGAGED/opt-out — never resumes
  stopReason  String?

  @@index([stoppedAt, nextRunAt]) // cron due-runs query
}

// Token/cost ledger per tenant (margin visibility from day one).
model LlmUsage {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  purpose      String // "parse" | "triage" | "draft" | "followup"
  model        String
  inputTokens  Int
  outputTokens Int

  @@index([businessId, createdAt])
}

// ---------------------------------------------------------------------------
// Venue discovery (Phase 10.2, ADR-004) — the sales agent's prospect list.
// ---------------------------------------------------------------------------

enum VenueKind {
  BAR
  ROOFTOP
  HOTEL
  RESTAURANT
  EVENT_SPACE
  CLUB
  OTHER
}

enum VenueStatus {
  DISCOVERED      // found by a scanner or seed — not yet judged
  QUALIFIED       // scored + fit — eligible for pitching (10.3)
  PITCH_DRAFTED   // pitch awaiting owner approval
  PITCHED         // pitch sent to the venue's published contact
  REPLIED         // venue answered — conversation begins
  IN_CONVERSATION // active back-and-forth
  BOOKED          // won — hard-stops all automation
  DEAD            // lost/unresponsive — hard-stops all automation
  SUPPRESSED      // never contact again (opt-out, C&D, owner kill) — never resurrected
}

enum SignalType {
  NEW_OPENING  // venue just opened (press/roundup/new listing)
  OPENING_SOON // announced/under construction/staffing up to open
  HIRING       // hiring events/bar staff — activity proxy
  NEW_SOCIAL   // brand-new venue social account
  PRESS        // other press coverage
  MANUAL       // owner added it by hand
}

// One prospect venue, TENANT-SCOPED: every artist gets their own venue rows
// for v1 — simpler isolation (status/score/suppression are inherently
// per-artist anyway). FUTURE REFACTOR: a global venue graph (one canonical
// Venue + per-tenant VenueProspect join) once multiple tenants hunt the same
// metros and discovery cost is worth sharing.
model Venue {
  id                 String      @id @default(cuid())
  businessId         String
  business           Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  name               String
  city               String
  country            String // ISO-2, recipient-side — drives the 10.3 jurisdiction rules
  kind               VenueKind   @default(OTHER)
  website            String?
  instagram          String?
  bookingEmail       String?
  bookingContactName String?
  contactSource      String? // where the email was found (venue site/press/...) — provenance for trust
  status             VenueStatus @default(DISCOVERED)
  fitScore           Int? // 0-100 from lib/venues/score.ts
  fitReasons         String[]    @default([]) // <=3 plain-language reasons (feed card)
  caution            String? // <=1 plain-language caution
  lastSignalAt       DateTime?
  pitchedAt          DateTime?
  suppressedReason   String?

  signals VenueSignal[]
  pitches VenuePitch[]

  @@unique([businessId, name, city]) // dedup key for ingest upserts
  @@index([businessId, status])
  @@index([businessId, fitScore])
}

// One observed piece of evidence about a venue (append-only provenance trail).
model VenueSignal {
  id         String     @id @default(cuid())
  venueId    String
  venue      Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  type       SignalType
  summary    String // one plain-language line, e.g. "Rooftop bar opened May 28 per Manchester Evening News"
  sourceUrl  String // dedup key per venue — same URL never appended twice
  observedAt DateTime // when the signal was true (publish date), not when we saw it
  createdAt  DateTime   @default(now())

  @@index([venueId])
}

enum VenuePitchStatus {
  PENDING   // drafted, awaiting owner review
  APPROVED  // owner approved — parked until a mailbox is connected (10.5)
  DISCARDED // owner killed it; venue returns to DISCOVERED
  SENT      // 10.5: delivered via the artist's own mailbox
  EXPIRED   // went stale before a decision
}

// One generated venue pitch (Phase 10.3, ADR-004). NOT unique per venue —
// a discarded pitch may be followed by a fresh draft later; history stays.
// The dedupe rule (max one PENDING per venue) is enforced in the action, not
// the schema.
model VenuePitch {
  id         String           @id @default(cuid())
  venueId    String
  venue      Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  businessId String
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  subject    String
  body       String // clean editable copy — the jurisdiction footer is NEVER stored here
  language   String           @default("en")
  status     VenuePitchStatus @default(PENDING)
  // Snapshot of lib/outreach/jurisdiction.ts mode at draft time ("STANDARD" |
  // "CONSENT" | "STRICT") — drives the review card's handoff/auto-send rules.
  jurisdictionMode String
  // LLM provenance (optional — LlmUsage holds the token ledger).
  model        String?
  inputTokens  Int?
  outputTokens Int?
  // Owner edits (voice-tuning signal, same pattern as Draft.editedBody).
  editedSubject String?
  editedBody    String?
  decidedAt     DateTime?

  @@index([venueId])
  @@index([businessId, status])
}

// Master per-tenant do-not-contact list (ADR-004 hard cap). Checked at ingest
// (never create a venue around a suppressed email) and again before any send.
model OutreachSuppression {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email      String // ALWAYS lowercased before write/compare
  reason     String // "unsubscribe" | "cease-and-desist" | "owner" | ...
  createdAt  DateTime @default(now())

  @@unique([businessId, email])
}

// Marketing email captures (free tools, templates download, waitlist-ish).
model MarketingContact {
  id        String   @id @default(cuid())
  email     String
  source    String // "reply-generator" | "templates" | "roi-calculator"
  createdAt DateTime @default(now())

  @@unique([email, source])
}
